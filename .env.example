#Copy to `.env.local` and fill in values. Never commit `.env.local`.

# ── Supabase ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xhzpmeplpsgnhfzgleaz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Fail-fast guard: ensures code points at the right Supabase project.
NEXT_PUBLIC_SUPABASE_PROJECT_REF=xhzpmeplpsgnhfzgleaz

# Server-only service role — required for webhooks, entitlement claims, profile upsert.
# Never prefix with NEXT_PUBLIC_ or import in client code.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe — keys ───────────────────────────────────────────────────────────────
# Publishable key (safe for browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret key — server-only. Never expose to client.
STRIPE_SECRET_KEY=

# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint.
STRIPE_WEBHOOK_SECRET=

# ── Stripe — price IDs (NEXT_PUBLIC — used by client components) ────────────────
# These are the live prices on the new CNPJ Stripe account.
NEXT_PUBLIC_PRICE_ASSESSMENT=price_1TYF7sLqKfCkbv0vKvmuXHFv
NEXT_PUBLIC_PRICE_ROADMAP=price_1TYF81LqKfCkbv0vhoXnDltZ
NEXT_PUBLIC_PRICE_MONTHLY=price_1TYF8gLqKfCkbv0vHmj73P2s
NEXT_PUBLIC_PRICE_ANNUAL=price_1TYF8tLqKfCkbv0viiVboOdW

# ── Stripe — price IDs (server-only fallback for webhook resolution) ─────────────
# Same values as NEXT_PUBLIC_PRICE_* — kept server-only for defense-in-depth.
# The webhook uses these to resolve product_key when Stripe metadata is empty
# (e.g. immediately after account migration before metadata is backfilled).
STRIPE_PRICE_BRAIN_PROFILE=price_1TYF7sLqKfCkbv0vKvmuXHFv
STRIPE_PRICE_ROADMAP_28_DAY=price_1TYF81LqKfCkbv0vhoXnDltZ
STRIPE_PRICE_MEMBERSHIP_MONTHLY=price_1TYF8gLqKfCkbv0vHmj73P2s
STRIPE_PRICE_MEMBERSHIP_ANNUAL=price_1TYF8tLqKfCkbv0viiVboOdW

# ── Stripe — V2 3-plan subscription model (server-only; intro → renewal) ─────────
# Each plan needs TWO recurring prices provisioned in Stripe:
#   INTRO   — recurring price whose interval == the intro window, billed once
#             (the schedule advances after 1 cycle). Provision in TEST mode first.
#   RENEWAL — the standard recurring rate after the intro window.
# The browser never sends these IDs; it sends only a plan_key, which the server
# resolves here. Leave blank until provisioned — checkout fails closed (503).
#
#   1-Week:  $10.50 / 7 days   → $43.50 / month   (intro price interval: week ×1)
#   4-Week:  $19.99 / 28 days  → $43.50 / month   (intro price interval: week ×4)
#   12-Week: $34.99 / 84 days  → $89.99 / 3 months (intro price interval: week ×12)
STRIPE_PRICE_PLAN_1WEEK_INTRO=
STRIPE_PRICE_PLAN_1WEEK_RENEWAL=
STRIPE_PRICE_PLAN_4WEEK_INTRO=
STRIPE_PRICE_PLAN_4WEEK_RENEWAL=
STRIPE_PRICE_PLAN_12WEEK_INTRO=
STRIPE_PRICE_PLAN_12WEEK_RENEWAL=

# ── Analytics / Meta Ads measurement ─────────────────────────────────────────
# Browser Pixel ID. Safe to expose; leave blank to disable Meta browser tracking.
NEXT_PUBLIC_META_PIXEL_ID=1787404968898761

# Optional server-side Pixel ID override for future Conversions API use.
META_PIXEL_ID=1787404968898761

# Server-side Conversions API. Leave blank to keep the app in Pixel-only mode.
# Checkout, webhooks, and builds must continue to work without this value.
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
META_CONVERSIONS_API_VERSION=v23.0

# ── Google Tag Manager + GA4 (GA4 is configured inside GTM) ──────────────────
# Container ID, e.g. GTM-XXXXXXX. GTM (and the dataLayer events) load only when
# this is set. Configure GA4 as a tag inside GTM; do not hardcode GA4 here.
NEXT_PUBLIC_GTM_ID=

# ── Microsoft Clarity ────────────────────────────────────────────────────────
# Clarity project ID. Clarity loads only when this is set.
NEXT_PUBLIC_CLARITY_ID=

# Distributed rate limiting (required before paid traffic in production)
# Use a Vercel/serverless-safe Redis REST backend such as Upstash Redis REST.
# Never expose these to the browser.
RATE_LIMIT_REDIS_REST_URL=
RATE_LIMIT_REDIS_REST_TOKEN=
RATE_LIMIT_HMAC_SECRET=

# ── Result email infrastructure (PR 7A — disabled by default) ────────────────
# Transactional result-email sending remains off unless explicitly enabled.
RESULT_EMAIL_SENDING_ENABLED=false
# Optional override for absolute links in result emails (defaults to https://getfocusroute.com).
RESULT_EMAIL_SITE_ORIGIN=
# Template version used in deterministic idempotency keys.
RESULT_EMAIL_TEMPLATE_VERSION=1
# Use "mock" only in local/test environments.
RESULT_EMAIL_PROVIDER=
# Optional local guard; mock is always forbidden when NODE_ENV=production.
RESULT_EMAIL_ALLOW_MOCK=
