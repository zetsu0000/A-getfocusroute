#Copy to `.env.local` and fill in values. Never commit `.env.local`.

# ── Supabase ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xhzpmeplpsgnhfzgleaz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Fail-fast guard: ensures code points at the right Supabase project.
NEXT_PUBLIC_SUPABASE_PROJECT_REF=xhzpmeplpsgnhfzgleaz

# Server-only service role — required for webhooks, entitlement claims, profile upsert.
# Never prefix with NEXT_PUBLIC_ or import in client code.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe — keys ───────────────────────────────────────────────────────────────
# Publishable key (safe for browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret key — server-only. Never expose to client.
STRIPE_SECRET_KEY=

# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint.
STRIPE_WEBHOOK_SECRET=

# ── Stripe — price IDs (NEXT_PUBLIC — used by client components) ────────────────
# These are the live prices on the new CNPJ Stripe account.
NEXT_PUBLIC_PRICE_ASSESSMENT=price_1TYF7sLqKfCkbv0vKvmuXHFv
NEXT_PUBLIC_PRICE_ROADMAP=price_1TYF81LqKfCkbv0vhoXnDltZ
NEXT_PUBLIC_PRICE_MONTHLY=price_1TYF8gLqKfCkbv0vHmj73P2s
NEXT_PUBLIC_PRICE_ANNUAL=price_1TYF8tLqKfCkbv0viiVboOdW

# ── Stripe — price IDs (server-only fallback for webhook resolution) ─────────────
# Same values as NEXT_PUBLIC_PRICE_* — kept server-only for defense-in-depth.
# The webhook uses these to resolve product_key when Stripe metadata is empty
# (e.g. immediately after account migration before metadata is backfilled).
STRIPE_PRICE_BRAIN_PROFILE=price_1TYF7sLqKfCkbv0vKvmuXHFv
STRIPE_PRICE_ROADMAP_28_DAY=price_1TYF81LqKfCkbv0vhoXnDltZ
STRIPE_PRICE_MEMBERSHIP_MONTHLY=price_1TYF8gLqKfCkbv0vHmj73P2s
STRIPE_PRICE_MEMBERSHIP_ANNUAL=price_1TYF8tLqKfCkbv0viiVboOdW

# ── Analytics / Meta Ads measurement ─────────────────────────────────────────
# Browser Pixel ID. Safe to expose; leave blank to disable Meta browser tracking.
NEXT_PUBLIC_META_PIXEL_ID=

# Server-side Conversions API. Leave blank to disable CAPI silently.
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
META_CONVERSIONS_API_VERSION=v23.0
